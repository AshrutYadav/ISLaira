{
  "train_path":       "data/train.json",
  "dev_path":         "data/dev.json",
  "test_path":        "data/test.json",
  "word_vocab_path":  "data/word_vocab.json",

  "use_gloss":        false,
  "gloss_vocab_path": null,
  "lambda_recognition": 0.0,
  "lambda_translation": 1.0,

  "pose_dim":            1728,
  "d_model":             512,
  "nhead":               8,
  "num_encoder_layers":  4,
  "num_decoder_layers":  4,
  "dim_feedforward":     4096,
  "dropout":             0.1,
  "max_seq_len":         4096,

  "batch_size":          32,
  "gradient_accumulation_steps": 1,
  "num_workers":         4,

  "lr":              0.0003,
  "beta1":           0.9,
  "beta2":           0.998,
  "weight_decay":    0.0001,
  "lr_decay":        0.5,
  "patience":        20,

  "max_epochs":          200,
  "early_stop_patience": 60,
  "eval_every":          5,
  "save_every":          5,
  "beam_size":           5,
  "length_penalty":      1.0,

  "checkpoint_dir": "checkpoints/",
  "export_dir":     "exports/"
}
